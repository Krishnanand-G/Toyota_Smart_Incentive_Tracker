generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OFFICER
}

enum MonthlySaleStatus {
  DRAFT
  SUBMITTED
}

model User {
  id           String        @id @default(cuid())
  authId       String        @unique
  email        String        @unique
  fullName     String?
  officerId    String?       @unique
  photoUrl     String?
  passwordHash String?
  role         Role          @default(OFFICER)
  isActive     Boolean       @default(true)
  monthlySales MonthlySale[]
  saleEntries  SaleEntry[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  @@index([role, isActive])
}

model CarModel {
  id          String            @id @default(cuid())
  name        String
  modelName   String
  baseSuffix  String?
  variant     String?
  imageUrl    String
  description String?
  isActive    Boolean           @default(true)
  saleItems   MonthlySaleItem[]
  saleEntries SaleEntry[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  @@index([isActive, name])
}

model IncentiveSlab {
  id            String   @id @default(cuid())
  minUnits      Int
  maxUnits      Int?
  perUnitAmount Decimal  @db.Decimal(10, 2)
  label         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MonthlySale {
  id             String            @id @default(cuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id])
  monthKey       String
  status         MonthlySaleStatus @default(DRAFT)
  submittedAt    DateTime?
  totalUnits     Int               @default(0)
  totalIncentive Decimal           @default(0) @db.Decimal(12, 2)
  items          MonthlySaleItem[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([userId, monthKey])
}

model MonthlySaleItem {
  id         String     @id @default(cuid())
  monthlyId  String
  monthly    MonthlySale @relation(fields: [monthlyId], references: [id], onDelete: Cascade)
  carModelId String
  carModel   CarModel   @relation(fields: [carModelId], references: [id])
  units      Int        @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([monthlyId, carModelId])
}

model SaleEntry {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  carModelId String
  carModel   CarModel @relation(fields: [carModelId], references: [id])
  soldAt     DateTime
  createdAt  DateTime @default(now())

  @@index([userId, soldAt])
  @@index([soldAt])
}
