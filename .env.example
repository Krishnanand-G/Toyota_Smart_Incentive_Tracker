DATABASE_URL="postgresql://user:password@localhost:5432/toyota_tracker"
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-public-anon-key"

# Optional — required for admin password provisioning and officer login creation
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Demo credentials — shown on localhost by default; hidden on Vercel unless you opt in:
# NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS="true"
# NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS="false"
# NEXT_PUBLIC_DEMO_ADMIN_EMAIL="admin@toyota.local"
# NEXT_PUBLIC_DEMO_ADMIN_PASSWORD="admin123"
# NEXT_PUBLIC_DEMO_OFFICER_EMAIL="officer@toyota.local"
# NEXT_PUBLIC_DEMO_OFFICER_PASSWORD="officer123"
